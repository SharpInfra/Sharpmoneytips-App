{
  "name": "sharpmoneytips-mobile",
  "description": "Fortune-50 grade B2C mobile app foundation (React Native + Expo + TypeScript)",
  "main": "index.ts",
  "version": "3.0.0",
  "packageManager": "pnpm@9.1.4",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "start": "expo start --host localhost --port 8080",
    "start:web": "expo start --web --host localhost --port 8080 --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web --host localhost --port 8080 --clear",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "test": "echo \"Error: no test specified\" && exit 1",
    "reset-project": "node ./scripts/reset-project.js",
    "ci": "pnpm run typecheck && pnpm run lint:check && pnpm run format:check"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~54.0.31",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linking": "~8.0.11",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/react": "~19.1.17",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.36.0",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.3.3",
    "typescript": "~5.9.3"
  },
  "private": true
}
